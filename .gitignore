# -------------------------
# OS / SYSTEM
# -------------------------
.DS_Store
Thumbs.db
ehthumbs.db
Icon?
._*

# -------------------------
# PHP / COMPOSER
# -------------------------
/vendor/
/composer.lock
/.phpunit.result.cache

# Symfony / Laravel / Generic PHP caches
/var/cache/
/var/log/
/storage/logs/
/storage/framework/cache/
/storage/framework/sessions/
/storage/framework/views/

# -------------------------
# NODE / JAVASCRIPT
# -------------------------
/node_modules/
/npm-debug.log*
/yarn-debug.log*
/yarn-error.log*
/pnpm-debug.log*
/package-lock.json
/yarn.lock
/pnpm-lock.yaml

# Build output
/dist/
/build/
/public/build/
/public/dist/
/.parcel-cache/
/.vite/
/vite.config.ts.timestamp*

# -------------------------
# ENVIRONMENT FILES
# -------------------------
.env
.env.*
!.env.example

# -------------------------
# JETBRAINS / PHPSTORM
# -------------------------
.idea/
*.iml
out/

# JetBrains workspace files
.idea/**/workspace.xml
.idea/**/tasks.xml
.idea/**/usage.statistics.xml
.idea/**/dictionaries
.idea/**/shelf

# PhpStorm generated files
.idea/**/php.xml
.idea/**/webServers.xml
.idea/**/dataSources/
.idea/**/dataSources.local.xml

# -------------------------
# LOGS / TEMP
# -------------------------
*.log
*.tmp
*.temp
*.cache
*.swp
*.swo

# -------------------------
# MISC
# -------------------------
/coverage/
/.cache/
/tmp/
/temp/
/logs/
/sessions/
/uploads/
/storage/app/public
